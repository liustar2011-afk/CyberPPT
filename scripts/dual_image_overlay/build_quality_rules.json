{
  "schema": "cyberppt.dual_image.build_quality_rules.v1",
  "rules": [
    {
      "id": "build.template_gate_pass",
      "stage": "build",
      "severity": "error",
      "description": "Template rebuild must consume required template files and export state.",
      "kind": "report_valid",
      "report": "template_gate",
      "evidence_required": true
    },
    {
      "id": "build.page_understanding_consumed",
      "stage": "build",
      "severity": "error",
      "description": "Build gate must consume page_understanding artifacts for dual-image editable overlay pages.",
      "kind": "page_understanding_consumed",
      "report": "source_capture_gate",
      "evidence_required": true
    }
  ]
}
