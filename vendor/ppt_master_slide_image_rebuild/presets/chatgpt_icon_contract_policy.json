{
  "profile": "chatgpt_precise_rebuild_icon_contract",
  "scope": "chatgpt_actions_only",
  "version": "1.0",
  "activation": {
    "manifest_execution_profile": "chatgpt_precise_rebuild",
    "requires_icon_manifest": true
  },
  "icon_policy": {
    "require_icon_manifest": true,
    "require_data_icon_id": true,
    "fallback_icon_forbidden": true,
    "missing_icon_is_error": true,
    "require_bbox": true,
    "bbox_position_tolerance_px": 3,
    "bbox_size_tolerance_px": 4,
    "min_visible_pixel_ratio": 0.015,
    "style_check": true,
    "max_stroke_width_px": 2.5,
    "min_bbox_fill_ratio": 0.12,
    "max_bbox_fill_ratio": 0.85,
    "min_padding_ratio": 0.08,
    "max_stroke_width_spread_px": 0.75,
    "prefer_asset_svg": true,
    "ppt_builtin_shape_limit": "simple_geometry_only"
  },
  "implementation_policy": {
    "asset_svg_first": true,
    "emoji_forbidden": true,
    "silent_default_icon_forbidden": true,
    "unimplemented_icon_raises_error": true
  }
}
