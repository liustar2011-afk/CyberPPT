    {"source_text": "(E106)", "display_text": "(E106)", "role": "evidence", "container_id": "e106", "bbox": [1174, 90, 1234, 110], "font_size": 12.5, "fill": "#111111", "bold": true, "align": "right", "v_align": "middle"},
    {"source_text": "注：现有材料以方法论与框架设计为主，暂无独立财务测算数据支撑", "display_text": "注：现有材料以方法论与框架设计为主，暂无独立财务测算数据支撑", "role": "caveat", "container_id": "caveat", "bbox": [42, 220, 640, 238], "font_size": 8.5, "fill": "#666666", "align": "left", "v_align": "middle"},
    {"source_text": "1", "display_text": "1", "role": "body", "container_id": "n1", "bbox": [58, 268, 88, 300], "font_size": 15, "fill": "#FFFFFF", "bold": true, "align": "center", "v_align": "middle"},
    {"source_text": "补齐企业能力可信表达短板", "display_text": "补齐企业能力可信表达短板", "role": "body", "container_id": "i1", "bbox": [188, 270, 588, 304], "font_size": 15, "fill": "#111111", "bold": true, "align": "left", "v_align": "middle"},
    {"source_text": "2", "display_text": "2", "role": "body", "container_id": "n2", "bbox": [660, 268, 690, 300], "font_size": 15, "fill": "#FFFFFF", "bold": true, "align": "center", "v_align": "middle"},
    {"source_text": "坚持分角色、分场景、分维度、重证据", "display_text": "坚持分角色、分场景、分维度、重证据", "role": "body", "container_id": "i2", "bbox": [790, 270, 1210, 304], "font_size": 15, "fill": "#111111", "bold": true, "align": "left", "v_align": "middle"},
    {"source_text": "3", "display_text": "3", "role": "body", "container_id": "n3", "bbox": [58, 356, 88, 388], "font_size": 15, "fill": "#FFFFFF", "bold": true, "align": "center", "v_align": "middle"},
    {"source_text": "监测是评价有效性的关键支撑", "display_text": "监测是评价有效性的关键支撑", "role": "body", "container_id": "i3", "bbox": [188, 358, 620, 392], "font_size": 15, "fill": "#111111", "bold": true, "align": "left", "v_align": "middle"},
    {"source_text": "4", "display_text": "4", "role": "body", "container_id": "n4", "bbox": [660, 356, 690, 388], "font_size": 15, "fill": "#FFFFFF", "bold": true, "align": "center", "v_align": "middle"},
    {"source_text": "服务产品必须进入真实业务流程", "display_text": "服务产品必须进入真实业务流程", "role": "body", "container_id": "i4", "bbox": [790, 358, 1210, 392], "font_size": 15, "fill": "#111111", "bold": true, "align": "left", "v_align": "middle"},
    {"source_text": "5", "display_text": "5", "role": "body", "container_id": "n5", "bbox": [58, 444, 88, 476], "font_size": 15, "fill": "#FFFFFF", "bold": true, "align": "center", "v_align": "middle"},
    {"source_text": "数据基础设施应服务于场景化能力证明", "display_text": "数据基础设施应服务于场景化能力证明", "role": "body", "container_id": "i5", "bbox": [188, 446, 645, 480], "font_size": 15, "fill": "#111111", "bold": true, "align": "left", "v_align": "middle"},
    {"source_text": "6", "display_text": "6", "role": "body", "container_id": "n6", "bbox": [660, 444, 690, 476], "font_size": 15, "fill": "#FFFFFF", "bold": true, "align": "center", "v_align": "middle"},
    {"source_text": "组织实施采用五方协同模式", "display_text": "组织实施采用五方协同模式", "role": "body", "container_id": "i6", "bbox": [790, 446, 1210, 480], "font_size": 15, "fill": "#111111", "bold": true, "align": "left", "v_align": "middle"},
    {"source_text": "7", "display_text": "7", "role": "body", "container_id": "n7", "bbox": [58, 536, 88, 568], "font_size": 15, "fill": "#FFFFFF", "bold": true, "align": "center", "v_align": "middle"},
