  "items": [
    {
      "source_text": "本场景围绕企业海外发展能力评价，建设统一入口、统一证据、统一评价和统一结果应用体系",
      "display_text": "本场景围绕企业海外发展能力评价，建设统一入口、统一证据、统一评价和统一结果应用体系",
      "role": "title",
      "container_id": "title",
      "relative_bbox": [
        0,
        0,
        1,
        1
      ],
      "font_size": 18,
      "font_family": "Arial",
